<Window x:Class="FinanceWidget.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Widget Settings" Height="250" Width="300"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Icon="pack://application:,,,/icon.png"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Stock/ETF Symbol (e.g. JEPQ:NASDAQ):" Grid.Row="0" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="TickerTextBox" Grid.Row="1" Height="25" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

        <CheckBox x:Name="UseBetaCheckBox" Grid.Row="2" Margin="0,0,0,15" FontWeight="Bold">
            <TextBlock TextWrapping="Wrap" Text="Use Google Finance Beta UI (Experimental)"/>
        </CheckBox>

        <Button x:Name="SaveButton" Content="Save" Grid.Row="6" Width="80" Height="30" HorizontalAlignment="Right" Click="SaveButton_Click"/>
    </Grid>
</Window>
