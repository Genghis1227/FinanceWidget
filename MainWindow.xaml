<Window x:Class="FinanceWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Finance Widget" Height="480" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        Icon="pack://application:,,,/icon.png"
        Loaded="Window_Loaded"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome 
            CaptionHeight="20" 
            ResizeBorderThickness="10" 
            GlassFrameThickness="0" 
            CornerRadius="10" />
    </WindowChrome.WindowChrome>
    
    <Grid Background="Transparent">
        <!-- Main Browser -->
        <Border x:Name="WidgetBorder" CornerRadius="10" Background="Transparent" ClipToBounds="True" Margin="10">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add New Widget" Click="AddNewWidget_Click" />
                    <MenuItem Header="Settings" Click="Settings_Click" />
                    <MenuItem Header="Keep on Top" x:Name="KeepOnTopMenuItem" IsCheckable="True" IsChecked="False" Click="KeepOnTop_Click" />
                    <Separator />
                    <MenuItem Header="Release Notes" Click="ReleaseNotes_Click" />
                    <MenuItem Header="Check for Updates" Click="CheckForUpdates_Click" />
                    <Separator />
                    <MenuItem Header="Login to Google" Click="LoginToGoogle_Click" />
                    <MenuItem Header="Return to Finance" x:Name="ReturnToFinanceMenuItem" Click="ReturnToFinance_Click" Visibility="Collapsed" />
                    <Separator />
                    <MenuItem Header="Close Widget" Click="CloseWidget_Click" />
                </ContextMenu>
            </Border.ContextMenu>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- Drag Handle -->
                <Border Grid.Row="0" Background="#f1f3f4" Cursor="SizeAll" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock x:Name="TickerLabel" Text="" FontSize="11" FontWeight="Bold" Foreground="#5f6368" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Rectangle Width="24" Height="2" Fill="#dadce0" Margin="0,1.5" RadiusX="1" RadiusY="1"/>
                            <Rectangle Width="24" Height="2" Fill="#dadce0" Margin="0,1.5" RadiusX="1" RadiusY="1"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <Grid Grid.Row="1" x:Name="BrowserContainer">
                    <wv2:WebView2 x:Name="Browser" DefaultBackgroundColor="Transparent"/>
                    
                    <!-- Login Suggestion Banner -->
                    <Border x:Name="LoginSuggestionBorder" VerticalAlignment="Bottom" Margin="10" Background="#ffffff" BorderBrush="#dadce0" BorderThickness="1" CornerRadius="8" Visibility="Collapsed" Panel.ZIndex="100">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" />
                        </Border.Effect>
                        <Grid Margin="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Sign in to Google" FontWeight="Bold" FontSize="12" Foreground="#202124"/>
                                <TextBlock Text="Track your watchlist and get better results." FontSize="11" Foreground="#5f6368"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Sign In" Margin="10,0" Padding="12,4" Background="#1a73e8" Foreground="White" BorderThickness="0" Cursor="Hand" Click="LoginToGoogle_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Grid.Column="2" Content="✕" Background="Transparent" Foreground="#5f6368" BorderThickness="0" FontSize="14" Cursor="Hand" Click="DismissLoginSuggestion_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>
