<Window x:Class="FinanceWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Finance Widget" Height="480" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        Icon="pack://application:,,,/icon.png"
        Loaded="Window_Loaded"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome 
            CaptionHeight="20" 
            ResizeBorderThickness="10" 
            GlassFrameThickness="0" 
            CornerRadius="10" />
    </WindowChrome.WindowChrome>
    
    <Grid Background="Transparent">
        <!-- Main Browser -->
        <Border x:Name="WidgetBorder" CornerRadius="10" Background="Transparent" ClipToBounds="True" Margin="10">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add New Widget" Click="AddNewWidget_Click" />
                    <MenuItem Header="Use Google Beta Site" x:Name="UseBetaSiteMenuItem" IsCheckable="True" Click="UseBetaSite_Click" />
                    <MenuItem Header="Keep on Top" x:Name="KeepOnTopMenuItem" IsCheckable="True" IsChecked="False" Click="KeepOnTop_Click" />
                    <Separator />
                    <MenuItem Header="Release Notes" Click="ReleaseNotes_Click" />
                    <MenuItem Header="Check for Updates" Click="CheckForUpdates_Click" />
                    <Separator />
                    <MenuItem Header="Login to Google" Click="LoginToGoogle_Click" />
                    <MenuItem Header="Return to Finance" x:Name="ReturnToFinanceMenuItem" Click="ReturnToFinance_Click" Visibility="Collapsed" />
                    <MenuItem Header="Refresh" Click="Refresh_Click" />
                    <Separator />
                    <MenuItem Header="Close Widget" Click="CloseWidget_Click" />
                </ContextMenu>
            </Border.ContextMenu>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- Drag Handle -->
                <Border x:Name="DragHandleBorder" Grid.Row="0" Height="20" Background="#f1f3f4" Cursor="SizeAll" MouseLeftButtonDown="Window_MouseLeftButtonDown" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Grid>
                        <TextBlock x:Name="TickerLabel" Text="" FontSize="11" FontWeight="Bold" Foreground="#5f6368" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Rectangle Width="24" Height="2" Fill="#dadce0" Margin="0,1.5" RadiusX="1" RadiusY="1"/>
                            <Rectangle Width="24" Height="2" Fill="#dadce0" Margin="0,1.5" RadiusX="1" RadiusY="1"/>
                        </StackPanel>
                        <Button x:Name="RefreshButton" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="RefreshButton_Click" ToolTip="Refresh widget content" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBorder" CornerRadius="10" Background="Transparent">
                                                    <Path Data="M13.6,2.3 C12.2,0.9 10.2,0 8,0 C3.6,0 0,3.6 0,8 C0,12.4 3.6,16 8,16 C11.7,16 14.8,13.4 15.7,10 L13.6,10 C12.8,12.3 10.6,14 8,14 C4.7,14 2,11.3 2,8 C2,4.7 4.7,2 8,2 C9.7,2 11.1,2.7 12.2,3.8 L9,7 L16,7 L16,0 L13.6,2.3 Z" 
                                                          Fill="#5f6368" 
                                                          Stretch="Uniform" 
                                                          Width="10" Height="10" 
                                                          x:Name="PathIcon"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="#e8eaed" />
                                                        <Setter TargetName="PathIcon" Property="Fill" Value="#202124" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="#dadce0" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
                
                <Grid Grid.Row="1" x:Name="BrowserContainer">
                    <wv2:WebView2 x:Name="Browser" DefaultBackgroundColor="Transparent"/>
                    
                    <!-- Login Suggestion Banner -->
                    <Border x:Name="LoginSuggestionBorder" VerticalAlignment="Bottom" Margin="10" Background="#ffffff" BorderBrush="#dadce0" BorderThickness="1" CornerRadius="8" Visibility="Collapsed" Panel.ZIndex="100">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" />
                        </Border.Effect>
                        <Grid Margin="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Get a Better Experience" FontWeight="Bold" FontSize="12" Foreground="#202124"/>
                                <TextBlock Text="Sign in to sync your watchlists and customized view." FontSize="11" Foreground="#5f6368"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Sign In" Margin="10,0" Padding="12,4" Background="#1a73e8" Foreground="White" BorderThickness="0" Cursor="Hand" Click="LoginToGoogle_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Grid.Column="2" Content="✕" Background="Transparent" Foreground="#5f6368" BorderThickness="0" FontSize="14" Cursor="Hand" Click="DismissLoginSuggestion_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>
