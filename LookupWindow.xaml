<Window x:Class="FinanceWidget.LookupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Popular Tickers" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Icon="pack://application:,,,/icon.png"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="12" Background="White" BorderBrush="#dadce0" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2" />
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,15">
                <TextBlock Text="Popular Tickers" FontSize="20" FontWeight="SemiBold" Foreground="#202124" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" 
                        FontSize="18" Foreground="#5f6368" Cursor="Hand" Click="Close_Click" Margin="180,0,0,0"/>
            </StackPanel>

            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="HeaderTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="14" FontWeight="Medium" Margin="5,2"/>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                
                <TabItem Header="Stocks">
                    <ListBox x:Name="StocksList" BorderThickness="0" Margin="0,10,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Symbol}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#5f6368"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Add" Click="AddTicker_Click" Tag="{Binding Symbol}" 
                                            Padding="10,2" Background="#f1f3f4" BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>

                <TabItem Header="ETFs">
                    <ListBox x:Name="EtfsList" BorderThickness="0" Margin="0,10,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Symbol}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#5f6368"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Add" Click="AddTicker_Click" Tag="{Binding Symbol}" 
                                            Padding="10,2" Background="#f1f3f4" BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>

                <TabItem Header="Crypto">
                    <ListBox x:Name="CryptoList" BorderThickness="0" Margin="0,10,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Symbol}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#5f6368"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Add" Click="AddTicker_Click" Tag="{Binding Symbol}" 
                                            Padding="10,2" Background="#f1f3f4" BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
            </TabControl>

            <Button Grid.Row="2" Content="Close" Click="Close_Click" HorizontalAlignment="Right" Margin="0,15,0,0"
                    Width="80" Height="32" Background="#1a73e8" Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>
